DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"
# Generate separate production-only values for AUTH_SECRET and NEXTAUTH_SECRET.
AUTH_SECRET="replace-with-random-32-plus-character-secret"
# 32 random bytes, base64 encoded. Generate locally with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="replace-with-32-byte-base64-key"
RETENTION_DRY_RUN="true"
MAX_RETENTION_DELETE_PER_RUN="100"
EXPORT_SIGNED_URL_TTL_SECONDS="1800"
NEXT_PUBLIC_APP_NAME="Hospital Risk Report & Management System"
GOOGLE_CLIENT_ID="replace-with-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-oauth-client-secret"
NEXTAUTH_SECRET="replace-with-random-32-plus-character-secret"
NEXTAUTH_URL="https://your-vercel-domain.example"
APP_BASE_URL="https://your-vercel-domain.example"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="WKR-HRMS <noreply@your-domain.example>"
CRON_SECRET="replace-with-random-cron-secret"
# Production seed safety: keep false outside local development.
SEED_DEV_USERS="false"
