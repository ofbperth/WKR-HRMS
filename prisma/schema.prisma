generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}








model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         String
  unitId       String?
  unit         Unit?    @relation(fields: [unitId], references: [id])
  isActive     Boolean  @default(true)
  authProvider String   @default("CREDENTIALS")
  googleId     String?  @unique
  image        String?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reportedIncidents Incident[] @relation("ReportedIncidents")
  reviewedIncidents Incident[] @relation("ReviewedIncidents")
  closedIncidents   Incident[] @relation("ClosedIncidents")
  rcaKpiOwner       RCA[]      @relation("RcaKpiOwner")
  rcaApproved       RCA[]      @relation("RcaApprover")
  actionOwned       ActionPlan[] @relation("ActionOwner")
  actionVerified    ActionPlan[] @relation("ActionVerifier")
  comments          Comment[]
  attachments       Attachment[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  exportAccessGrants ExportAccessGrant[]
  exportJobs       ExportJob[]
  invitesSent       UserInvite[] @relation("InvitedBy")
}

model Unit {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("หน่วยงาน")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  userInvites       UserInvite[]
  reportedIncidents Incident[] @relation("ReporterUnit")
  incidentIncidents Incident[] @relation("IncidentUnit")
}

model RiskCode {
  id                String            @id @default(cuid())
  code              String            @unique
  nameTh            String
  nameEn            String?
  clinicalOrGeneral String
  simpleCategory    String
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  incidents Incident[]
}

model Incident {
  id                String             @id @default(cuid())
  incidentNo        String             @unique
  reportedAt        DateTime           @default(now())
  occurredAt        DateTime
  rcaDueAt          DateTime?          @map("rca_due_at")
  reportedById      String?
  reportedBy        User?              @relation("ReportedIncidents", fields: [reportedById], references: [id], onDelete: SetNull)
  reporterUnitId    String
  reporterUnit      Unit               @relation("ReporterUnit", fields: [reporterUnitId], references: [id])
  incidentUnitId    String
  incidentUnit      Unit               @relation("IncidentUnit", fields: [incidentUnitId], references: [id])
  location          String?
  patientHn         String?
  patientAn         String?
  hnEncrypted       String?            @map("hn_encrypted")
  anEncrypted       String?            @map("an_encrypted")
  reporterNameEncrypted String?        @map("reporter_name_encrypted")
  medicationRight   String?
  affectedType      String
  clinicalOrGeneral String
  simpleCategory    String
  riskCodeId        String
  riskCode          RiskCode           @relation(fields: [riskCodeId], references: [id])
  title             String
  description       String
  immediateAction   String?
  severity          String
  isSentinel        Boolean            @default(false)
  needRmSupport     Boolean            @default(false)
  status            String             @default("New")
  lifecycleStatus   String             @default("ACTIVE") @map("lifecycle_status")
  archivedAt        DateTime?          @map("archived_at")
  deletedAt         DateTime?          @map("deleted_at")
  retentionReviewRequired Boolean      @default(false) @map("retention_review_required")
  legalHold         Boolean            @default(false) @map("legal_hold")
  underInvestigation Boolean           @default(false) @map("under_investigation")
  reviewedById      String?
  reviewedBy        User?              @relation("ReviewedIncidents", fields: [reviewedById], references: [id])
  reviewedAt        DateTime?
  closedById        String?
  closedBy          User?              @relation("ClosedIncidents", fields: [closedById], references: [id])
  closedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  rca         RCA?
  actionPlans ActionPlan[]
  comments    Comment[]
  attachments Attachment[]

  @@index([incidentNo])
  @@index([createdAt])
  @@index([occurredAt])
  @@index([reportedById])
  @@index([incidentUnitId])
  @@index([riskCodeId])
  @@index([severity])
  @@index([status])
  @@index([rcaDueAt])
  @@index([archivedAt])
  @@index([deletedAt])
  @@index([lifecycleStatus])
  @@index([isSentinel])
  @@index([needRmSupport])
  @@index([occurredAt, status])
  @@index([occurredAt, severity])
  @@index([occurredAt, incidentUnitId])
  @@index([incidentUnitId, status])
  @@index([riskCodeId, occurredAt])
  @@index([clinicalOrGeneral, occurredAt])
  @@index([simpleCategory, occurredAt])
}

model RCA {
  id                             String    @id @default(cuid())
  incidentId                     String    @unique
  incident                       Incident  @relation(fields: [incidentId], references: [id])
  problemStatement               String?
  timeline                       String?
  contributingHuman              String?
  contributingProcess            String?
  contributingEquipment          String?
  contributingEnvironment        String?
  contributingCommunication      String?
  contributingIT                 String?
  rootCause                      String?
  rcaEncrypted                   String?   @map("rca_encrypted")
  preventiveAction               String?
  kpi                            String?
  kpiOwnerId                     String?
  kpiOwner                       User?     @relation("RcaKpiOwner", fields: [kpiOwnerId], references: [id])
  needRmSupport                  Boolean   @default(false)
  status                         String    @default("Draft")
  submittedAt                    DateTime?
  approvedById                   String?
  approvedBy                     User?     @relation("RcaApprover", fields: [approvedById], references: [id])
  approvedAt                     DateTime?
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  actionPlans ActionPlan[]

  @@index([status])
}

model ActionPlan {
  id                  String           @id @default(cuid())
  incidentId          String
  incident            Incident         @relation(fields: [incidentId], references: [id])
  rcaId               String?
  rca                 RCA?             @relation(fields: [rcaId], references: [id])
  title               String
  description         String?
  ownerId             String?
  owner               User?            @relation("ActionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  coOwnerText         String?
  dueDate             DateTime
  status              String           @default("NotStarted")
  evidenceText        String?
  evidenceUrl         String?
  kpiName             String?
  kpiTarget           String?
  kpiResult           String?
  effectivenessReview String?
  verifiedById        String?
  verifiedBy          User?            @relation("ActionVerifier", fields: [verifiedById], references: [id])
  verifiedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([dueDate])
  @@index([status])
  @@index([ownerId])
  @@index([incidentId])
}

model Comment {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  message    String
  createdAt  DateTime @default(now())

  @@index([incidentId])
}

model Attachment {
  id           String   @id @default(cuid())
  incidentId   String
  incident     Incident @relation(fields: [incidentId], references: [id])
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  fileName     String
  fileUrl      String
  fileType     String?
  createdAt    DateTime @default(now())

  @@index([incidentId])
}

model Notification {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  type              String
  title             String
  message           String
  relatedIncidentId String?
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  userRole   String?   @map("role")
  action     String
  entityType String
  entityId   String?
  ipAddress  String?   @map("ip_address")
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
  @@index([entityType])
  @@index([entityType, entityId, createdAt])
}

model MonthlyReport {
  id                String   @id @default(cuid())
  year              Int
  month             Int
  generatedAt       DateTime @default(now())
  generatedBySystem Boolean  @default(true)
  summaryJson       String
  fileUrl           String?

  @@unique([year, month])
}

model AuthSettings {
  id                String   @id @default("default")
  googleEnabled     Boolean  @default(false)
  allowedDomains    String   @default("[]")
  allowedEmails     String   @default("[]")
  allowAutoProvision Boolean @default(false)
  defaultRole       String   @default("Reporter")
  defaultIsActive   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model UserInvite {
  id          String    @id @default(cuid())
  email       String    @unique
  role        String
  unitId      String?
  unit        Unit?     @relation(fields: [unitId], references: [id])
  invitedById String?
  invitedBy   User?     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  status      String    @default("Pending")
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?

  @@index([email])
  @@index([status])
}

model AutomationRun {
  id          String   @id @default(cuid())
  jobName     String
  status      String
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  message     String?
  resultJson  String?
  error       String?
  triggeredBy String?

  @@index([jobName])
  @@index([startedAt])
  @@index([status])
}

model RetentionRun {
  id              String   @id @default(cuid())
  mode            String
  status          String
  startedAt       DateTime @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  reviewed        Int      @default(0)
  archived        Int      @default(0)
  softDeleted     Int      @default(0) @map("soft_deleted")
  filesDeleted    Int      @default(0) @map("files_deleted")
  skippedProtected Int     @default(0) @map("skipped_protected")
  stoppedByFailsafe Boolean @default(false) @map("stopped_by_failsafe")
  message         String?
  resultJson      String?  @map("result_json")
  createdById     String?  @map("created_by_id")

  @@index([startedAt])
  @@index([status])
}

model CacheEntry {
  id          String   @id @default(cuid())
  cacheKey    String   @unique @map("cache_key")
  cacheType   String   @map("cache_type")
  unitId      String?  @map("unit_id")
  reportType  String?  @map("report_type")
  filtersJson String   @map("filters_json")
  payloadJson String   @map("payload_json")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([cacheType])
  @@index([unitId])
  @@index([reportType])
  @@index([expiresAt])
}

model StorageObject {
  id          String   @id @default(cuid())
  bucket      String
  objectKey   String   @unique @map("object_key")
  objectType  String   @map("object_type")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  storageTier String   @default("HOT") @map("storage_tier")
  compressed  Boolean  @default(false)
  readOnly    Boolean  @default(false) @map("read_only")
  expiresAt   DateTime? @map("expires_at")
  archivedAt  DateTime? @map("archived_at")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([objectType])
  @@index([targetType, targetId])
  @@index([storageTier])
  @@index([expiresAt])
  @@index([archivedAt])
  @@index([deletedAt])
}

model ExportAccessGrant {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id])
  kind         String
  role         String
  unitId       String?  @map("unit_id")
  reason       String
  filtersJson  String   @map("filters_json")
  scope        String
  tokenJti     String   @unique @map("token_jti")
  expiresAt    DateTime @map("expires_at")
  downloadedAt DateTime? @map("downloaded_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([kind, createdAt])
  @@index([expiresAt])
}

model ExportJob {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  kind            String
  role            String
  unitId          String?  @map("unit_id")
  reason          String
  scope           String
  filtersJson     String   @map("filters_json")
  status          String
  attemptCount    Int      @default(0) @map("attempt_count")
  requestedAt     DateTime @default(now()) @map("requested_at")
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  expiresAt       DateTime? @map("expires_at")
  filename        String?
  contentType     String?  @map("content_type")
  rowCount        Int?     @map("row_count")
  storageObjectId String?  @unique @map("storage_object_id")
  lastError       String?  @map("last_error")

  @@index([userId, requestedAt])
  @@index([status, requestedAt])
  @@index([kind, requestedAt])
  @@index([expiresAt])
}
